---
// src/components/FilterDropdown.astro
interface Props {
  label: string;
  options: string[];
  filterType: 'style' | 'color' | 'layout';
}

const { label, options, filterType } = Astro.props;
const filterId = `filter-${filterType}`;
---

<div class="filter-dropdown">
  <label for={filterId} class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">
    {label}
  </label>
  <select 
    id={filterId}
    class="filter-select w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors cursor-pointer"
    data-filter-type={filterType}
  >
    <option value="all">全部</option>
    {options.map(option => (
      <option value={option}>{option}</option>
    ))}
  </select>
</div>
