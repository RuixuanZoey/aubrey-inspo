---
// 独立注册/登录页面
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>注册 / 登录 | AubreyInspo</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f5;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 40px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; color: #111; }
    .sub { color: #666; font-size: 14px; margin-bottom: 28px; }

    .tabs {
      display: flex; margin-bottom: 24px;
      border-bottom: 2px solid #e5e7eb;
    }
    .tab {
      flex: 1; text-align: center; padding: 10px 0;
      font-size: 15px; font-weight: 600; cursor: pointer;
      border: none; background: none; color: #999;
      border-bottom: 2px solid transparent; margin-bottom: -2px;
    }
    .tab.active { color: #4f46e5; border-bottom-color: #4f46e5; }

    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #333; margin-bottom: 6px; }
    .form-group input {
      width: 100%; padding: 10px 14px; font-size: 15px;
      border: 1px solid #d1d5db; border-radius: 8px; outline: none;
    }
    .form-group input:focus {
      border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
    }

    .btn {
      width: 100%; padding: 12px; font-size: 15px; font-weight: 600;
      color: white; background: #4f46e5; border: none; border-radius: 8px;
      cursor: pointer; transition: background 0.15s;
    }
    .btn:hover { background: #4338ca; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .msg {
      padding: 12px 14px; border-radius: 8px; font-size: 13px;
      margin-bottom: 16px; display: none; line-height: 1.5;
    }
    .msg.error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; display: block; }
    .msg.success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; display: block; }
    .msg.info { background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; display: block; }

    .back-link { margin-top: 16px; font-size: 13px; text-align: center; }
    .back-link a { color: #6b7280; text-decoration: underline; }

    .debug { font-size: 11px; color: #999; margin-top: 8px; word-break: break-all; }
  </style>
</head>
<body>
<div class="card">
  <h1>AubreyInspo 后台</h1>
  <p class="sub" id="status-text">注册新账号或登录</p>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('signup')">注册</button>
    <button class="tab" onclick="switchTab('login')">登录</button>
  </div>

  <div class="msg" id="msg"></div>

  <form id="signup-form" onsubmit="return handleSignup(event)">
    <div class="form-group">
      <label for="su-email">邮箱</label>
      <input type="email" id="su-email" placeholder="you@example.com" required autocomplete="email">
    </div>
    <div class="form-group">
      <label for="su-pw">密码</label>
      <input type="password" id="su-pw" placeholder="至少 6 位" minlength="6" required autocomplete="new-password">
    </div>
    <button type="submit" class="btn" id="su-btn">注册</button>
  </form>

  <form id="login-form" style="display:none" onsubmit="return handleLogin(event)">
    <div class="form-group">
      <label for="li-email">邮箱</label>
      <input type="email" id="li-email" placeholder="you@example.com" required autocomplete="email">
    </div>
    <div class="form-group">
      <label for="li-pw">密码</label>
      <input type="password" id="li-pw" placeholder="输入密码" required autocomplete="current-password">
    </div>
    <button type="submit" class="btn" id="li-btn">登录</button>
  </form>

  <div class="back-link">
    <a href="/admin/">← 返回后台</a>
  </div>
</div>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tab').forEach(function(t, i) {
    t.classList.toggle('active', (i===0 && tab==='signup') || (i===1 && tab==='login'));
  });
  document.getElementById('signup-form').style.display = (tab==='signup') ? 'block' : 'none';
  document.getElementById('login-form').style.display = (tab==='login') ? 'block' : 'none';
  document.getElementById('msg').className = 'msg';
  document.getElementById('status-text').textContent = (tab==='signup') ? '注册新账号' : '登录已有账号';
}

function showMsg(type, text) {
  var m = document.getElementById('msg');
  m.className = 'msg ' + type;
  m.innerHTML = text;
}

function handleSignup(e) {
  e.preventDefault();
  var email = document.getElementById('su-email').value.trim();
  var password = document.getElementById('su-pw').value;
  if (!email || !password) return false;

  var btn = document.getElementById('su-btn');
  btn.disabled = true;
  btn.textContent = '注册中…';

  fetch('/.netlify/identity/signup', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email, password: password })
  })
  .then(function(r) { return r.json().then(function(d) { return {ok:r.ok,status:r.status,data:d}; }); })
  .then(function(result) {
    if (result.ok) {
      // 注册成功，Netlify 会发送确认邮件
      showMsg('success',
        '<strong>注册成功！</strong><br><br>' +
        '已向 <b>' + email + '</b> 发送确认邮件。<br><br>' +
        '请查收邮件（检查垃圾箱），点击邮件中的确认链接激活账号。<br>' +
        '激活后回到此页面登录即可。'
      );
      switchTab('login');
      document.getElementById('li-email').value = email;
    } else if (result.status === 422) {
      showMsg('error', '该邮箱已注册过，请直接登录或使用其他邮箱。');
      switchTab('login');
      document.getElementById('li-email').value = email;
    } else {
      var msg = result.data && result.data.msg ? result.data.msg : JSON.stringify(result.data);
      showMsg('error', '注册失败：' + msg);
    }
  })
  .catch(function(err) {
    showMsg('error', '网络请求失败，请检查网络后重试。<br><small>' + err.message + '</small>');
  })
  .finally(function() {
    btn.disabled = false;
    btn.textContent = '注册';
  });
  return false;
}

function handleLogin(e) {
  e.preventDefault();
  var email = document.getElementById('li-email').value.trim();
  var password = document.getElementById('li-pw').value;
  if (!email || !password) return false;

  var btn = document.getElementById('li-btn');
  btn.disabled = true;
  btn.textContent = '登录中…';

  fetch('/.netlify/identity/token?grant_type=password', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email, password: password })
  })
  .then(function(r) { return r.json().then(function(d) { return {ok:r.ok,status:r.status,data:d}; }); })
  .then(function(result) {
    if (result.ok && result.data.access_token) {
      showMsg('success', '登录成功！即将跳转…');
      // 存储 token 并通过 identity widget 确认登录
      setTimeout(function() {
        document.location.href = '/admin/';
      }, 300);
    } else if (result.status === 400) {
      showMsg('error', '邮箱或密码错误，请重试。');
    } else if (result.status === 401) {
      showMsg('error', '密码错误，请重试。');
    } else {
      var msg = result.data && result.data.error_description ? result.data.error_description :
                result.data && result.data.msg ? result.data.msg : JSON.stringify(result.data);
      showMsg('error', '登录失败：' + msg);
    }
  })
  .catch(function(err) {
    showMsg('error', '网络请求失败，请检查网络后重试。');
  })
  .finally(function() {
    btn.disabled = false;
    btn.textContent = '登录';
  });
  return false;
}
</script>
</body>
</html>
