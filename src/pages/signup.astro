---
// Netlify Identity Widget 驱动的登录/注册页 — 用官方 UI，不自己调 API
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AubreyInspo — 注册 / 登录</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f5;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 48px 40px;
      width: 100%;
      max-width: 380px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      text-align: center;
    }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 8px; color: #111; }
    .sub { color: #666; font-size: 14px; margin-bottom: 32px; }

    .actions { display: flex; flex-direction: column; gap: 12px; }
    .btn {
      width: 100%; padding: 12px 20px; font-size: 15px; font-weight: 600;
      border-radius: 8px; cursor: pointer; transition: all 0.15s;
      border: none;
    }
    .btn-primary {
      color: white; background: #4f46e5;
    }
    .btn-primary:hover { background: #4338ca; }
    .btn-outline {
      color: #4f46e5; background: white; border: 1.5px solid #d1d5db;
    }
    .btn-outline:hover { border-color: #4f46e5; background: #f5f3ff; }
    .divider {
      display: flex; align-items: center; color: #9ca3af; font-size: 13px;
      margin: 4px 0;
    }
    .divider::before, .divider::after {
      content: ""; flex: 1; height: 1px; background: #e5e7eb;
    }
    .divider::before { margin-right: 12px; }
    .divider::after { margin-left: 12px; }

    .back-link { margin-top: 24px; font-size: 13px; }
    .back-link a { color: #6b7280; text-decoration: underline; }

    .msg {
      padding: 12px 14px; border-radius: 8px; font-size: 13px;
      margin-bottom: 20px; display: none; line-height: 1.5; text-align: left;
    }
    .msg.error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; display: block; }
    .msg.success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; display: block; }
    .msg.info { background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; display: block; }

    .steps { text-align: left; background: #f9fafb; border-radius: 8px; padding: 14px 16px; margin-bottom: 24px; font-size: 13px; color: #4b5563; }
    .steps p { margin-bottom: 6px; }
    .steps p:last-child { margin-bottom: 0; }
    .steps code { background: #e5e7eb; padding: 1px 5px; border-radius: 4px; font-size: 12px; }
  </style>
</head>
<body>

<div class="card">
  <h1>AubreyInspo</h1>
  <p class="sub">管理后台入口</p>

  <div class="msg" id="msg"></div>

  <div class="steps">
    <p>1. 点击下方"注册新账号"或"登录已有账号"</p>
    <p>2. 在弹出的窗口操作（<strong>如果弹窗被拦截，请点地址栏右侧图标允许</strong>）</p>
    <p>3. 完成后自动跳转后台</p>
  </div>

  <div class="actions">
    <button class="btn btn-primary" id="signup-btn" onclick="openSignup(event)">
      注册新账号
    </button>
    <div class="divider">或</div>
    <button class="btn btn-outline" id="login-btn" onclick="openLogin(event)">
      登录已有账号
    </button>
  </div>

  <div class="back-link">
    <a href="/admin/">← 返回后台</a>
  </div>
</div>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

<script is:inline>
(function() {
  var identityReady = false;
  var msgEl = document.getElementById('msg');
  var signupBtn = document.getElementById('signup-btn');
  var loginBtn = document.getElementById('login-btn');

  function showMsg(type, text) {
    msgEl.className = 'msg ' + type;
    msgEl.innerHTML = text;
  }

  window.openSignup = function(e) {
    e.preventDefault();
    if (!identityReady) {
      showMsg('info', '身份组件加载中，请稍等…');
      return;
    }
    showMsg('info', '正在打开注册窗口…');
    window.netlifyIdentity.open('signup');
  };

  window.openLogin = function(e) {
    e.preventDefault();
    if (!identityReady) {
      showMsg('info', '身份组件加载中，请稍等…');
      return;
    }
    showMsg('info', '正在打开登录窗口…');
    window.netlifyIdentity.open('login');
  };

  // 初始化 Identity Widget
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", function(user) {
      identityReady = true;
      signupBtn.disabled = false;
      loginBtn.disabled = false;
      if (user) {
        // 已登录，直接跳转后台
        showMsg('success', '已登录，跳转到后台…');
        setTimeout(function() {
          document.location.href = '/admin/';
        }, 500);
      }
    });

    window.netlifyIdentity.on("login", function() {
      showMsg('success', '登录成功！跳转到后台…');
      setTimeout(function() {
        document.location.href = '/admin/';
      }, 500);
    });

    window.netlifyIdentity.on("signup", function(newUser) {
      showMsg('success', '注册成功！即将跳转…');
      setTimeout(function() {
        document.location.href = '/admin/';
      }, 300);
    });

    window.netlifyIdentity.on("error", function(err) {
      showMsg('error', '操作失败：' + (err.message || err));
    });

    window.netlifyIdentity.on("close", function() {
      // 用户关闭了弹窗但没有登录，清除之前的提示
      setTimeout(function() {
        if (msgEl.className.indexOf('success') < 0) {
          msgEl.className = 'msg';
          msgEl.innerHTML = '';
        }
      }, 1000);
    });

    // 初始化
    window.netlifyIdentity.init();
  } else {
    showMsg('error', '身份认证组件未能加载，请刷新页面重试。');
  }
})();
</script>
</body>
</html>
