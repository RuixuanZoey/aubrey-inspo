---
// 独立注册/登录页面
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>注册 / 登录 | AubreyInspo</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f5;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 40px;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      text-align: center;
    }
    h1 {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #111;
    }
    .subtitle {
      color: #666;
      font-size: 14px;
      margin-bottom: 32px;
    }
    .btn {
      width: 100%;
      padding: 14px;
      font-size: 15px;
      font-weight: 600;
      color: white;
      background: #4f46e5;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-bottom: 12px;
      transition: background 0.15s;
    }
    .btn:hover { background: #4338ca; }
    .btn-secondary {
      background: #f3f4f6;
      color: #374151;
    }
    .btn-secondary:hover { background: #e5e7eb; }
    .msg {
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 16px;
      display: none;
      text-align: left;
    }
    .msg.error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; display: block; }
    .msg.success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; display: block; }
    .msg.info { background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; display: block; }
    .back-link {
      margin-top: 16px;
      font-size: 13px;
    }
    .back-link a { color: #6b7280; text-decoration: underline; }
  </style>
</head>
<body>
<div class="card">
  <h1>AubreyInspo</h1>
  <p class="subtitle">内容管理后台</p>

  <div class="msg" id="msg"></div>

  <p style="font-size:14px;color:#666;margin-bottom:16px;">点击下方按钮注册新账号或登录</p>

  <button class="btn" id="signup-btn" onclick="doSignup()">注册新账号</button>
  <button class="btn btn-secondary" id="login-btn" onclick="doLogin()">已有账号？登录</button>

  <div class="back-link">
    <a href="/admin/">← 返回后台</a>
  </div>
</div>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

<script>
var identityReady = false;

function showMsg(type, text) {
  var m = document.getElementById('msg');
  m.className = 'msg ' + type;
  m.textContent = text;
}

function doSignup() {
  if (identityReady && window.netlifyIdentity) {
    window.netlifyIdentity.open('signup');
  } else {
    showMsg('info', '正在加载认证组件，请稍后再试...');
  }
}

function doLogin() {
  if (identityReady && window.netlifyIdentity) {
    window.netlifyIdentity.open('login');
  } else {
    showMsg('info', '正在加载认证组件，请稍后再试...');
  }
}

if (window.netlifyIdentity) {
  window.netlifyIdentity.on('init', function(user) {
    identityReady = true;
    console.log('Identity ready, user:', user);

    if (user) {
      // 已登录，直接跳转后台
      document.location.href = '/admin/';
      return;
    }

    // 监听登录和注册成功事件
    window.netlifyIdentity.on('login', function() {
      console.log('Login event fired, redirecting...');
      document.location.href = '/admin/';
    });

    window.netlifyIdentity.on('signup', function(newUser) {
      console.log('Signup event fired, user:', newUser);
      showMsg('success', '注册成功！正在跳转...');
      setTimeout(function() {
        document.location.href = '/admin/';
      }, 500);
    });
  });

  window.netlifyIdentity.on('error', function(err) {
    console.error('Identity error:', err);
    showMsg('error', '认证出错：' + (err.message || '请查看控制台'));
  });
}

// 3 秒后如果还没 ready，显示提示
setTimeout(function() {
  if (!identityReady) {
    showMsg('error', '认证组件加载超时，请刷新页面重试。');
  }
}, 5000);
</script>
</body>
</html>
