---
// src/pages/admin.astro
// Decap CMS 后台管理页面
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Manager | AubreyInspo</title>
  <style>
    #signup-hint {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: #666;
      background: white;
      padding: 12px 24px;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.12);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    #signup-hint a {
      color: #4f46e5;
      text-decoration: underline;
      cursor: pointer;
      font-weight: 600;
    }
    #signup-hint a:hover {
      color: #3730a3;
    }
    /* 深色模式适配 */
    @media (prefers-color-scheme: dark) {
      #signup-hint {
        background: #1f2937;
        color: #d1d5db;
        box-shadow: 0 2px 12px rgba(0,0,0,0.4);
      }
      #signup-hint a {
        color: #818cf8;
      }
    }
  </style>
</head>
<body>
  <!-- 注册/登录提示条：先隐藏，等确定 identity widget 可用后再显示 -->
  <div id="signup-hint" style="display:none">
    <span>首次使用？</span>
    <a href="javascript:;" id="signup-link">点击注册账号</a>
    <span>|</span>
    <a href="javascript:;" id="login-link">已有账号？登录</a>
  </div>

  <!-- 1. Netlify Identity 必须先加载 -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  
  <!-- 2. 然后加载 Decap CMS -->
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
  
  <!-- 3. 登录成功的重定向 + 注册/登录按钮逻辑 -->
  <script>
    (function() {
      var hint = document.getElementById('signup-hint');
      var signupBtn = document.getElementById('signup-link');
      var loginBtn = document.getElementById('login-link');

      function doSignup() {
        // 优先用 Identity widget 弹窗，失败则跳转页面
        if (window.netlifyIdentity && window.netlifyIdentity.open) {
          window.netlifyIdentity.open('signup');
        } else {
          document.location.href = '/.netlify/identity#signup';
        }
      }

      function doLogin() {
        if (window.netlifyIdentity && window.netlifyIdentity.open) {
          window.netlifyIdentity.open('login');
        } else {
          document.location.href = '/.netlify/identity#login';
        }
      }

      // 点击事件
      signupBtn.addEventListener('click', doSignup);
      loginBtn.addEventListener('click', doLogin);

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (user) {
            // 已登录，隐藏提示条
            hint.style.display = 'none';
          } else {
            // 未登录，显示提示条
            hint.style.display = 'flex';
          }
          window.netlifyIdentity.on("login", function() {
            document.location.href = "/admin/";
          });
          window.netlifyIdentity.on("signup", function(newUser) {
            // 注册成功后直接重定向
            document.location.href = "/admin/";
          });
        });

        // 超时保护：如果 3 秒没收到 init 事件也显示按钮
        setTimeout(function() {
          if (hint.style.display === 'none') {
            hint.style.display = 'flex';
          }
        }, 3000);
      } else {
        // identity widget 完全不可用，也显示按钮（走直接跳转）
        hint.style.display = 'flex';
      }
    })();
  </script>
</body>
</html>
