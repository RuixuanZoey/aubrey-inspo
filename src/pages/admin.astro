---
// src/pages/admin.astro
// Decap CMS 后台管理页面
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Manager | AubreyInspo</title>
  <style>
    #signup-hint {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: #666;
      background: white;
      padding: 12px 24px;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.12);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    #signup-hint button {
      color: #4f46e5;
      background: none;
      border: none;
      text-decoration: underline;
      cursor: pointer;
      font-weight: 600;
      font-size: inherit;
      font-family: inherit;
      padding: 0;
    }
    #signup-hint button:hover {
      color: #3730a3;
    }
    /* 深色模式适配 */
    @media (prefers-color-scheme: dark) {
      #signup-hint {
        background: #1f2937;
        color: #d1d5db;
        box-shadow: 0 2px 12px rgba(0,0,0,0.4);
      }
      #signup-hint button {
        color: #818cf8;
      }
    }
  </style>
</head>
<body>
  <!-- 注册/登录提示条 -->
  <div id="signup-hint" style="display:none">
    <span>首次使用？</span>
    <button type="button" id="signup-link">点击注册账号</button>
    <span>|</span>
    <button type="button" id="login-link">已有账号？登录</button>
  </div>

  <!-- 1. Netlify Identity 必须先加载 -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  
  <!-- 2. 然后加载 Decap CMS -->
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
  
  <!-- 3. 登录成功的重定向 + 注册/登录按钮逻辑 -->
  <script>
    (function() {
      var hint = document.getElementById('signup-hint');
      var signupBtn = document.getElementById('signup-link');
      var loginBtn = document.getElementById('login-link');

      // 点击注册：使用 Identity Widget 打开注册模态框
      signupBtn.addEventListener('click', function() {
        if (window.netlifyIdentity) {
          window.netlifyIdentity.open('signup');
        }
      });

      // 点击登录
      loginBtn.addEventListener('click', function() {
        if (window.netlifyIdentity) {
          window.netlifyIdentity.open('login');
        }
      });

      // 初始化处理
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (user) {
            hint.style.display = 'none';
          } else {
            hint.style.display = 'flex';
          }
        });

        window.netlifyIdentity.on("login", function() {
          document.location.href = "/admin/";
        });

        window.netlifyIdentity.on("signup", function() {
          document.location.href = "/admin/";
        });
      }

      // 确保按钮显示（如果 identity 加载较慢）
      setTimeout(function() {
        if (hint.style.display === 'none') {
          hint.style.display = 'flex';
        }
      }, 2000);
    })();
  </script>
</body>
</html>
