---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import MasonryGallery from '../components/MasonryGallery.astro';
import MatchCount from '../components/MatchCount.astro';
import Lightbox from '../components/Lightbox.astro';
import { getCollection } from 'astro:content';

const inspirations = await getCollection('inspirations');
// 按创建时间倒序排列
const sorted = inspirations.sort(
  (a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf()
);
---

<BaseLayout title="AubreyInspo - PPT 灵感库">
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
      AubreyInspo
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
      Aubrey 的 PPT 审美灵感库 —— 收集优质设计碎片，激发创作灵感
    </p>
  </section>

  <FilterBar />
  <MatchCount total={sorted.length} />
  <MasonryGallery inspirations={sorted} />
  <Lightbox inspirations={sorted} />
</BaseLayout>
